# OpenAI Responses API（必填）
# 注意：仅 OpenAI / Azure OpenAI 原生支持 Responses API
MSCRIPT_LLM_API_KEY=
MSCRIPT_LLM_BASE_URL=https://api.openai.com/v1
MSCRIPT_LLM_MODEL=gpt-4o-mini
MSCRIPT_LLM_TIMEOUT=120

# Semantic Scholar（可选，无 key 也能用，限速更严）
MSCRIPT_S2_API_KEY=

# 检索默认值
MSCRIPT_DEFAULT_YEARS=2
MSCRIPT_DEFAULT_MAX_ZONE=2
MSCRIPT_DEFAULT_TOP_K=30
