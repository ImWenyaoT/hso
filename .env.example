# Active LLM provider: gpt / deepseek / custom / xai / oauth / legacy
LLM_PROVIDER=gpt
HSO_LLM_TIMEOUT=120

# OpenAI GPT provider（默认主路径，走 Responses API）
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.4-mini

# DeepSeek provider（Chat Completions 兼容层）
# LLM_PROVIDER=deepseek
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-flash

# Custom OpenAI-compatible Chat Completions endpoint
# LLM_PROVIDER=custom
# LLM_API_KEY=
# LLM_BASE_URL=http://localhost:8000/v1
# LLM_MODEL=local-model

# Personal ChatGPT OAuth provider（先运行 `uv run hso login`）
# LLM_PROVIDER=oauth
OAUTH_MODEL=gpt-5.2

# Legacy compatibility for older HSO_* .env files
# HSO_LLM_PROVIDER=legacy
# HSO_LLM_API_KEY=
# HSO_LLM_BASE_URL=https://api.openai.com/v1
# HSO_LLM_MODEL=gpt-4o-mini

# Semantic Scholar（可选，无 key 也能用，限速更严）
HSO_S2_API_KEY=

# 检索默认值
HSO_DEFAULT_YEARS=2
HSO_DEFAULT_MAX_ZONE=2
HSO_DEFAULT_TOP_K=30
